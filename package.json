{
  "name": "gitlab-notifier",
  "version": "0.1.1",
  "description": "Get notifications from one or more GitLab instances",
  "license": "MIT",
  "scripts": {
    "start": "web-ext run --source-dir firefox/",
    "build": "web-ext build --source-dir firefox/ --artifacts-dir web-ext-artifacts/ --overwrite-dest",
    "lint": "web-ext lint --source-dir firefox/",
    "test": "vitest run",
    "sign": "./build.sh -s"
  },
  "devDependencies": {
    "vitest": "^4.1.4",
    "web-ext": "^8.3.0"
  }
}
